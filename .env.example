# Polymarket
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Opinion
OPINION_API_URL=https://api.opinion.xyz
OPINION_WS_URL=wss://ws.opinion.trade
OPINION_API_KEY=
OPINION_POLL_INTERVAL_SECONDS=2.0

# Limitless
LIMITLESS_WS_URL=wss://ws.limitless.exchange
LIMITLESS_API_URL=https://api.limitless.exchange
LIMITLESS_API_KEY=

# Limitless roster (auto-discovery)
LIMITLESS_ROSTER_POLL_SECONDS=30.0
LIMITLESS_ROSTER_EXPIRY_GRACE_SECONDS=300.0

# Pipeline
BUFFER_MAX_ROWS=100000
BUFFER_TTL_SECONDS=3600
LOG_LEVEL=INFO
FEATURE_OUTPUT_DIR=./output

# Metrics
METRICS_ENABLED=true
METRICS_PORT=8000
